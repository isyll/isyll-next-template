NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# App role (least privilege), the migration role, and the isolated admin role.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/app?sslmode=disable
ADMIN_DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

# ─── Authentication (BetterAuth) ─────────────────────────────────────────────
# Two fully isolated instances. Secrets must be ≥32 chars (generate with
# `openssl rand -base64 32`). `pnpm project:init` fills these in for you.
AUTH_USER_SECRET=
AUTH_USER_URL=http://localhost:3000
AUTH_ADMIN_SECRET=
AUTH_ADMIN_URL=http://localhost:3000

# ─── Social providers (optional) ─────────────────────────────────────────────
# Leave blank to disable a provider; it is hidden from the login page.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_APP_BUNDLE_IDENTIFIER=

# ─── Redis (ioredis) ─────────────────────────────────────────────────────────
# Backs session storage (BetterAuth secondaryStorage) and distributed rate
# limiting. Required in production; in dev, leave blank to fall back to the
# database (sessions) and an in-process limiter. Use `rediss://` for TLS.
REDIS_URL=

# ─── Observability ───────────────────────────────────────────────────────────
# Log verbosity (fatal|error|warn|info|debug|trace|silent).
LOG_LEVEL=info

# ─── Transactional email (Resend) ────────────────────────────────────────────
# Leave blank in dev to log emails to the console instead of sending them.
RESEND_API_KEY=
EMAIL_FROM=

# ─── Object storage (S3-compatible: AWS S3, Cloudflare R2, MinIO) ─────────────
# All required together to enable uploads. Set S3_ENDPOINT / S3_FORCE_PATH_STYLE
# for non-AWS providers. For the local MinIO from compose.dev.yaml, use:
#   S3_REGION=us-east-1
#   S3_BUCKET=app-uploads
#   S3_ACCESS_KEY_ID=minioadmin
#   S3_SECRET_ACCESS_KEY=minioadmin
#   S3_ENDPOINT=http://localhost:9000
#   S3_FORCE_PATH_STYLE=true
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=

# ─── Billing (Stripe) — optional ─────────────────────────────────────────────
# Leave blank to disable billing (the UI degrades to "unavailable"). Use test
# keys (`sk_test_…`) in dev. STRIPE_PRICE_ID is the recurring price the checkout
# sells; STRIPE_WEBHOOK_SECRET (`whsec_…`) verifies inbound webhook signatures
# (from `stripe listen` in dev, or the dashboard endpoint in prod).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ─── Analytics & search console (optional, client-side) ──────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# ─── Error tracking (Sentry) — entirely optional ─────────────────────────────
# Leave blank to disable (the SDK stays inert; no build plugin runs). Set the
# DSNs to capture server + client errors. ORG/PROJECT/AUTH_TOKEN additionally
# enable source-map upload at build and the admin monitoring dashboard.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Distributed tracing (OpenTelemetry / OTLP) — optional ───────────────────
# Set the collector base URL to enable OTLP export (blank = no-op tracer).
# Headers carry auth as `key=value,key2=value2`. When SENTRY_DSN is set, Sentry
# owns tracing and this exporter is not activated.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=

# ─── Retention (scheduled prune job — worker:jobs) ───────────────────────────
# Windows (days) to prune aged audit rows and processed outbox events; `dead`
# rows are kept. RETENTION_CRON drives the schedule (defaults: 365 / 30 / daily).
AUDIT_RETENTION_DAYS=365
OUTBOX_RETENTION_DAYS=30
RETENTION_CRON=0 3 * * *
