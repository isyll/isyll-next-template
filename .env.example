# =============================================================================
# Environment variables. Copy to `.env` at the repo root and fill in.
#   cp .env.example .env
# Validated at boot (apps/web via @t3-oss/env-nextjs, packages via Zod).
# =============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (PostgreSQL) ---------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
