{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en,fr",
  "import": ["@cspell/dict-fr-fr/cspell-ext.json"],
  "dictionaries": ["en_US", "fr-fr", "project-words"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
  ],
  "useGitignore": true,
  "ignorePaths": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/drizzle/**",
    "**/messages/*.d.json.ts",
    "pnpm-lock.yaml",
    "**/*.snap"
  ],
  "files": ["**/*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json}"]
}
