{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Drizzle ORM schema, client, validators and migrations (PostgreSQL).",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./validators": "./src/validators/index.ts",
    "./admin": "./src/admin.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/scripts/migrate.ts up",
    "db:rollback": "tsx src/scripts/migrate.ts down 1",
    "db:migrate:status": "tsx src/scripts/migrate.ts version",
    "db:migrate:new": "tsx src/scripts/migrate.ts new",
    "db:reference:generate": "tsx src/scripts/generate-reference-migrations.ts",
    "sql:lint": "sqlfluff lint migrations",
    "sql:fix": "sqlfluff fix migrations",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@workspace/core": "workspace:*",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "pg": "catalog:",
    "server-only": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "countries-and-timezones": "catalog:",
    "currency-codes": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-seed": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "world-countries": "catalog:"
  }
}
