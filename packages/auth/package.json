{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "BetterAuth: isolated end-user and admin (operator) auth instances.",
  "exports": {
    ".": "./src/index.ts",
    "./admin": "./src/admin-auth.ts",
    "./permissions": "./src/permissions.ts",
    "./social": "./src/social.ts",
    "./email": "./src/email.ts",
    "./env": "./src/env.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:generate": "better-auth generate --config ./src/auth.ts --output ../db/src/schema/auth.ts -y",
    "admin:sync-permissions": "tsx src/scripts/admin-cli.ts sync-permissions",
    "admin:create-operator": "tsx src/scripts/admin-cli.ts create-operator"
  },
  "dependencies": {
    "@workspace/core": "workspace:*",
    "@workspace/db": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "resend": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "picocolors": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
