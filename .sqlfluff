# SQLFluff config for the pure-SQL migrations. Requires SQLFluff (Python):
#   pipx install sqlfluff      # then: pnpm sql:lint / pnpm sql:fix
[sqlfluff]
dialect = postgres
templater = raw
max_line_length = 100
# The generated reference migrations (e.g. countries) exceed the default 20 kB
# parser-lock guard; 0 disables it so every file is linted/fixed.
large_file_skip_byte_limit = 0
# Long generated INSERT rows and reserved-word identifiers ("user") are
# intentional; PL/pgSQL bodies are opaque to the linter.
exclude_rules = layout.long_lines, references.keywords, references.quoting

[sqlfluff:indentation]
tab_space_size = 2
indent_unit = space

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = lower
