# Infrastructure / Docker Compose environment. Copy to `.env` at the repo root
# before running compose.prod.yaml. Production MUST override every secret.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=app

APP_DB_PASSWORD=change-me-app
MIGRATOR_DB_PASSWORD=change-me-migrator
ADMIN_DB_PASSWORD=change-me-admin

DATABASE_URL=postgres://app:change-me-app@db:5432/app?sslmode=disable
MIGRATION_DATABASE_URL=postgres://app_migrator:change-me-migrator@db:5432/app?sslmode=disable
ADMIN_DATABASE_URL=postgres://admin_service:change-me-admin@db:5432/app?sslmode=disable

AUTH_USER_SECRET=generate-with-openssl-rand-base64-32
AUTH_USER_URL=https://example.com
AUTH_ADMIN_SECRET=generate-a-DIFFERENT-secret-here
AUTH_ADMIN_URL=https://example.com
NEXT_PUBLIC_APP_URL=https://example.com

# Redis (sessions, rate limiting, cache, realtime pub/sub). Required in prod.
REDIS_PASSWORD=change-me-redis
REDIS_URL=redis://:change-me-redis@redis:6379

# Object storage (S3/R2/MinIO). The bundled MinIO uses S3_ACCESS_KEY_ID /
# S3_SECRET_ACCESS_KEY as its root credentials.
MINIO_ROOT_USER=change-me-minio
MINIO_ROOT_PASSWORD=change-me-minio-secret
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=app-uploads
S3_ACCESS_KEY_ID=change-me-minio
S3_SECRET_ACCESS_KEY=change-me-minio-secret
S3_FORCE_PATH_STYLE=true

# Transactional email (Resend). Absent → emails log to the console.
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com

# Error tracking (Sentry). Inert when unset.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Content-Security-Policy rollout. Set CSP_REPORT_ONLY=true to vet a policy and
# point CSP_REPORT_URI at /api/csp-report to collect violations.
CSP_REPORT_ONLY=
CSP_REPORT_URI=

# Retention sweep (worker:jobs). Defaults apply when unset; add a worker:jobs
# service to run the scheduled prune in production.
AUDIT_RETENTION_DAYS=
OUTBOX_RETENTION_DAYS=
RETENTION_CRON=
