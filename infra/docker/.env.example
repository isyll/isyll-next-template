# Infrastructure / Docker Compose environment.
# Copy to `.env` at the repo root before running compose.prod.yaml.
# (Local development reads these via compose defaults; production MUST override
# every secret below.)

# --- Postgres superuser (bootstrap only) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=app

# --- Least-privilege role passwords (created by initdb/00-roles.sh) ---
APP_DB_PASSWORD=change-me-app
MIGRATOR_DB_PASSWORD=change-me-migrator
ADMIN_DB_PASSWORD=change-me-admin

# --- Connection strings used by the app / migrator (role per concern) ---
# App role: DML on the public user tables only.
DATABASE_URL=postgres://app:change-me-app@db:5432/app
# Migration role: owns DDL; never used by the running app.
MIGRATION_DATABASE_URL=postgres://app_migrator:change-me-migrator@db:5432/app
# Admin role: DML on the isolated `admin` schema only.
ADMIN_DATABASE_URL=postgres://admin_service:change-me-admin@db:5432/app

# --- Auth (separate secrets per instance) ---
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://example.com
ADMIN_AUTH_SECRET=generate-a-DIFFERENT-secret-here
ADMIN_AUTH_URL=https://example.com
NEXT_PUBLIC_APP_URL=https://example.com

# Set to "true" only for the one-off run that provisions the first admin.
ADMIN_ALLOW_SIGNUP=false
