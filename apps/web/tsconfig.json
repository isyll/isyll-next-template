{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "vitest.config.mts",
    "playwright.config.ts",
    "global.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "e2e"]
}
