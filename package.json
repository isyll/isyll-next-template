{
  "name": "isyll-next-template",
  "version": "0.1.0",
  "private": true,
  "description": "Ultra-powerful, server-first Next.js 16 monorepo template.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "turbo watch dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,css,yml,yaml}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "test:load": "turbo run test:load",
    "spellcheck": "cspell --no-progress --gitignore \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json}\"",
    "check": "turbo run lint typecheck test build && pnpm run spellcheck && pnpm run format:check",
    "clean": "turbo run clean && rimraf .turbo",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "auth:generate": "turbo run auth:generate",
    "ui:add": "pnpm dlx shadcn@latest add -c apps/web",
    "project:init": "tsx scripts/init-project.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@cspell/dict-en_us": "catalog:",
    "@cspell/dict-fr-fr": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "rimraf": "^6.0.1",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
