{
  "name": "next-monorepo-template",
  "version": "0.1.0",
  "private": true,
  "description": "Ultra-powerful, server-first Next.js 16 monorepo template.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "turbo watch dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,css,yml,yaml}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "test:load": "k6 run tests/load/script.ts",
    "spellcheck": "cspell --no-progress --gitignore \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,json}\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "check": "turbo run lint typecheck test build && pnpm run spellcheck && pnpm run format:check",
    "clean": "turbo run clean && rimraf .turbo",
    "db:migrate": "turbo run db:migrate",
    "db:rollback": "turbo run db:rollback",
    "db:migrate:status": "turbo run db:migrate:status",
    "db:migrate:new": "pnpm --filter @workspace/db db:migrate:new",
    "db:reference:generate": "pnpm --filter @workspace/db db:reference:generate",
    "sql:lint": "pnpm --filter @workspace/db sql:lint",
    "sql:fix": "pnpm --filter @workspace/db sql:fix",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "auth:generate": "turbo run auth:generate",
    "admin:sync-permissions": "pnpm --filter @workspace/auth admin:sync-permissions",
    "admin:create-operator": "pnpm --filter @workspace/auth admin:create-operator",
    "ui:add": "pnpm dlx shadcn@latest add -c apps/web",
    "project:init": "tsx scripts/init-project.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@cspell/dict-en_us": "catalog:",
    "@cspell/dict-fr-fr": "catalog:",
    "@types/k6": "catalog:",
    "@types/node": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "rimraf": "^6.0.1",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
