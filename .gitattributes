# Normalize line endings: store text as LF in the repo, convert per-platform on
# checkout. Files Git detects as binary are left untouched.
* text=auto eol=lf

# Sources and config — always LF.
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.mdx     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.sql     text eol=lf
*.graphql text eol=lf
*.env     text eol=lf
*.svg     text eol=lf

# Shell scripts must stay LF and executable regardless of host platform.
*.sh      text eol=lf
*.bash    text eol=lf

# Windows-only scripts keep CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary assets — never normalize or diff as text.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.avif    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.mp4     binary
*.webm    binary

# Generated / vendored files: collapse in diffs and exclude from language stats.
pnpm-lock.yaml          linguist-generated=true -diff
*.snap                  linguist-generated=true
**/drizzle/**           linguist-generated=true
**/messages/*.d.json.ts linguist-generated=true
next-env.d.ts           linguist-generated=true

# Mark infra/tooling so GitHub language stats reflect application code.
**/*.test.ts            linguist-language=TypeScript
infra/**                linguist-detectable=false

# Richer diff hunk headers for these languages.
*.ts diff=typescript
*.tsx diff=typescript
*.css diff=css
*.md diff=markdown

# Keep CHANGELOG merges painless (union both sides).
CHANGELOG.md merge=union

# Files to drop from `git archive` / release tarballs.
.github/        export-ignore
.husky/         export-ignore
.vscode/        export-ignore
.idea/          export-ignore
tests/          export-ignore
*.test.ts       export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
